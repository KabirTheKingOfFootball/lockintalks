NEXT_PUBLIC_SITE_URL=https://lockintalks.com
# Copy these from Supabase Dashboard > Project Settings > API / API Keys.
# The URL must be only https://your-project-ref.supabase.co with no /rest/v1 or /auth/v1 path.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
# Legacy Supabase projects can use NEXT_PUBLIC_SUPABASE_ANON_KEY instead of the publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never prefix this with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=server_only_service_role_key_for_payment_updates
# Server-only. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
APP_SESSION_SECRET=replace-with-a-secure-random-32-byte-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Launch default: keep internal points/reward UI disabled until it is intentionally reintroduced.
NEXT_PUBLIC_LOCKIN_POINTS_ENABLED=false

# Optional production monitoring. Add these when Sentry is configured.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_TRACES_SAMPLE_RATE=0.1
